EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
EXPO_PUBLIC_SITE_URL=https://your-app-domain.example
SITE_URL=https://your-app-domain.example

# Current launch sign-in uses email/password plus a local profile fallback.
# Social sign-in can be revisited later when OAuth/app-store setup is ready.

# Set this in Convex env, not in a public Expo variable:
# npx convex env set OPENAI_API_KEY your_api_key
# Optional:
# npx convex env set OPENAI_TUTOR_MODEL gpt-5.4-mini

# Optional admin email notifications through Resend:
# npx convex env set RESEND_API_KEY re_your_resend_key --prod
# npx convex env set ADMIN_NOTIFICATION_FROM "Bible Study Tutor <notifications@biblestudytutor.org>" --prod
